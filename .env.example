# Configuración de Firebase - Cownect
# Obtén tus credenciales en: https://console.firebase.google.com
NEXT_PUBLIC_FIREBASE_API_KEY=tu_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=tu_proyecto.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=tu_proyecto_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=tu_proyecto.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=tu_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=tu_app_id

# Firebase Admin (servidor / rutas API de Next.js) — obligatorio para certificados y escrituras sin token del navegador
# Firebase Console → Configuración del proyecto → Cuentas de servicio → Generar nueva clave privada (JSON)
FIREBASE_PROJECT_ID=tu_proyecto_id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@tu_proyecto.iam.gserviceaccount.com
# Pega la clave del JSON entre comillas; los \n deben ser literales o reales según tu editor
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Alternativa (recomendado): ruta al JSON de cuenta de servicio
# FIREBASE_SERVICE_ACCOUNT_PATH=../cownect-xxxxxx-firebase-adminsdk-xxxx.json

# ADMIN_REVIEW_PASSWORD=tu_contraseña_para_validar_animales

# Google Drive - OAuth (carpeta en Mi unidad)
# Configura en Google Cloud Console: https://console.cloud.google.com
GOOGLE_DRIVE_FOLDER_ID=tu_folder_id
GOOGLE_DRIVE_CLIENT_ID=tu_client_id.apps.googleusercontent.com
GOOGLE_DRIVE_CLIENT_SECRET=tu_google_client_secret
GOOGLE_DRIVE_REFRESH_TOKEN=tu_refresh_token

# PayPal - ver PAYPAL_SETUP.md
# Configura en: https://developer.paypal.com
NEXT_PUBLIC_PAYPAL_CLIENT_ID=tu_paypal_client_id
PAYPAL_CLIENT_SECRET=tu_paypal_client_secret
PAYPAL_SANDBOX=true