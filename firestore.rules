rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'mufasaelrey13@gmail.com';
    }

    function isTrabajadorSesion() {
      return request.auth != null && request.auth.token.tipo == 'trabajador';
    }

    function ownerUidTrabajador() {
      return request.auth.token.owner_uid;
    }

    match /usuarios/{userId} {
      allow read: if request.auth != null && (
        request.auth.uid == userId ||
        (isTrabajadorSesion() && ownerUidTrabajador() == userId)
      );
      allow write: if request.auth != null && request.auth.uid == userId && !isTrabajadorSesion();
    }

    match /usuarios/{ownerUid}/trabajadores/{workerId} {
      allow read, write: if request.auth != null && request.auth.uid == ownerUid && !isTrabajadorSesion();
    }

    match /paypal_pending_orders/{orderId} {
      allow read, write: if true;
    }
    match /paypal_pending_subscriptions/{orderId} {
      allow read, write: if true;
    }

    match /animales/{animalId} {
      allow read: if request.auth != null && (
        resource.data.usuario_id == request.auth.uid ||
        (isTrabajadorSesion() && resource.data.usuario_id == ownerUidTrabajador())
      );
      allow create: if request.auth != null && (
        (!isTrabajadorSesion() && request.resource.data.usuario_id == request.auth.uid) ||
        (isTrabajadorSesion() && request.resource.data.usuario_id == ownerUidTrabajador())
      );
      allow update, delete: if request.auth != null && !isTrabajadorSesion() &&
        (resource.data.usuario_id == request.auth.uid || isAdmin());
    }

    match /eventos_animal/{eventoId} {
      allow read: if request.auth != null && (
        resource.data.usuario_id == request.auth.uid ||
        (isTrabajadorSesion() && resource.data.usuario_id == ownerUidTrabajador())
      );
      allow create: if request.auth != null && (
        request.resource.data.usuario_id == request.auth.uid ||
        (isTrabajadorSesion() && request.resource.data.usuario_id == ownerUidTrabajador())
      );
      allow update, delete: if false;
    }

    match /pesos/{docId} {
      allow read: if request.auth != null && (
        resource.data.usuario_id == request.auth.uid ||
        (isTrabajadorSesion() && resource.data.usuario_id == ownerUidTrabajador())
      );
      allow create: if request.auth != null && (
        request.resource.data.usuario_id == request.auth.uid ||
        (isTrabajadorSesion() && request.resource.data.usuario_id == ownerUidTrabajador())
      );
      allow update, delete: if request.auth != null && !isTrabajadorSesion() &&
        (resource.data.usuario_id == request.auth.uid || isAdmin());
    }

    match /vacunaciones/{docId} {
      allow read: if request.auth != null && (
        resource.data.usuario_id == request.auth.uid ||
        (isTrabajadorSesion() && resource.data.usuario_id == ownerUidTrabajador())
      );
      allow create: if request.auth != null && (
        request.resource.data.usuario_id == request.auth.uid ||
        (isTrabajadorSesion() && request.resource.data.usuario_id == ownerUidTrabajador())
      );
      allow update, delete: if request.auth != null && !isTrabajadorSesion() &&
        (resource.data.usuario_id == request.auth.uid || isAdmin());
    }

    match /compras/{docId} {
      allow read, write: if request.auth != null && !isTrabajadorSesion();
    }
    match /calificaciones/{docId} {
      allow read, write: if request.auth != null && !isTrabajadorSesion();
    }
    match /reportes/{docId} {
      allow read, write: if request.auth != null && !isTrabajadorSesion();
    }

    match /animal_certificates/{certId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && !isTrabajadorSesion() &&
        (request.resource.data.usuario_id == request.auth.uid || isAdmin());
      allow update, delete: if false;
    }
  }
}
