rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'mufasaelrey13@gmail.com';
    }

    function isTrabajadorSesion() {
      return request.auth != null && request.auth.token.tipo == 'trabajador';
    }

    function ownerUidTrabajador() {
      return request.auth.token.owner_uid;
    }

    function tienePerfilUsuario() {
      return exists(/databases/$(database)/documents/usuarios/$(request.auth.uid));
    }

    /** Perfil usuarios/{uid}; si no existe el doc, mapa vacio. */
    function perfilAuth() {
      return exists(/databases/$(database)/documents/usuarios/$(request.auth.uid))
        ? get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data
        : {};
    }

    /** Empleado kiosko: usuarios/{uid} con id_rancho_jefe = UID del dueno. */
    function esEmpleadoDelUsuario(userIdPropietario) {
      return request.auth != null
        && tienePerfilUsuario()
        && perfilAuth().id_rancho_jefe == userIdPropietario;
    }

    /** Dueno, empleado vinculado, o sesion trabajador custom del dueno. */
    function puedeLeerRecursoDe(uidDueno) {
      return request.auth != null && (
        uidDueno == request.auth.uid ||
        esEmpleadoDelUsuario(uidDueno) ||
        (isTrabajadorSesion() && ownerUidTrabajador() == uidDueno)
      );
    }

    /** Escritura datos del rancho del dueno (no sesion trabajador custom). */
    function puedeEscribirComoDuenoOEmpleado(uidDueno) {
      return request.auth != null
        && !isTrabajadorSesion()
        && (uidDueno == request.auth.uid || esEmpleadoDelUsuario(uidDueno) || isAdmin());
    }

    match /usuarios/{userId} {
      allow read: if request.auth != null && (
        request.auth.uid == userId ||
        esEmpleadoDelUsuario(userId) ||
        (isTrabajadorSesion() && ownerUidTrabajador() == userId)
      );
      allow write: if request.auth != null && request.auth.uid == userId && !isTrabajadorSesion();
    }

    match /usuarios/{ownerUid}/trabajadores/{workerId} {
      allow read, write: if request.auth != null && request.auth.uid == ownerUid && !isTrabajadorSesion();
    }

    match /paypal_pending_orders/{orderId} {
      allow read, write: if true;
    }
    match /paypal_pending_subscriptions/{orderId} {
      allow read, write: if true;
    }

    match /animales/{animalId} {
      allow read: if puedeLeerRecursoDe(resource.data.usuario_id);
      allow create: if request.auth != null && (
        (!isTrabajadorSesion() && request.resource.data.usuario_id == request.auth.uid) ||
        (isTrabajadorSesion() && request.resource.data.usuario_id == ownerUidTrabajador()) ||
        (tienePerfilUsuario() && perfilAuth().id_rancho_jefe == request.resource.data.usuario_id)
      );
      allow update, delete: if puedeEscribirComoDuenoOEmpleado(resource.data.usuario_id);
    }

    match /eventos_animal/{eventoId} {
      allow read: if puedeLeerRecursoDe(resource.data.usuario_id);
      allow create: if request.auth != null && (
        request.resource.data.usuario_id == request.auth.uid ||
        (isTrabajadorSesion() && request.resource.data.usuario_id == ownerUidTrabajador()) ||
        (tienePerfilUsuario() && perfilAuth().id_rancho_jefe == request.resource.data.usuario_id)
      );
      allow update, delete: if false;
    }

    match /pesos/{docId} {
      allow read: if puedeLeerRecursoDe(resource.data.usuario_id);
      allow create: if request.auth != null && (
        request.resource.data.usuario_id == request.auth.uid ||
        (isTrabajadorSesion() && request.resource.data.usuario_id == ownerUidTrabajador()) ||
        (tienePerfilUsuario() && perfilAuth().id_rancho_jefe == request.resource.data.usuario_id)
      );
      allow update, delete: if puedeEscribirComoDuenoOEmpleado(resource.data.usuario_id);
    }

    match /vacunaciones/{docId} {
      allow read: if puedeLeerRecursoDe(resource.data.usuario_id);
      allow create: if request.auth != null && (
        request.resource.data.usuario_id == request.auth.uid ||
        (isTrabajadorSesion() && request.resource.data.usuario_id == ownerUidTrabajador()) ||
        (tienePerfilUsuario() && perfilAuth().id_rancho_jefe == request.resource.data.usuario_id)
      );
      allow update, delete: if puedeEscribirComoDuenoOEmpleado(resource.data.usuario_id);
    }

    /** Coleccion producciones (FirebaseProduccionRepository). */
    match /producciones/{docId} {
      allow read: if puedeLeerRecursoDe(resource.data.usuario_id);
      allow create: if request.auth != null && (
        request.resource.data.usuario_id == request.auth.uid ||
        (isTrabajadorSesion() && request.resource.data.usuario_id == ownerUidTrabajador()) ||
        (tienePerfilUsuario() && perfilAuth().id_rancho_jefe == request.resource.data.usuario_id)
      );
      allow update, delete: if puedeEscribirComoDuenoOEmpleado(resource.data.usuario_id);
    }

    /** Alias historico produccion/ si quedaron docs viejos. */
    match /produccion/{docId} {
      allow read: if puedeLeerRecursoDe(resource.data.usuario_id);
      allow create: if request.auth != null && (
        request.resource.data.usuario_id == request.auth.uid ||
        (isTrabajadorSesion() && request.resource.data.usuario_id == ownerUidTrabajador()) ||
        (tienePerfilUsuario() && perfilAuth().id_rancho_jefe == request.resource.data.usuario_id)
      );
      allow update, delete: if puedeEscribirComoDuenoOEmpleado(resource.data.usuario_id);
    }

    match /ranchos/{docId} {
      allow read: if puedeLeerRecursoDe(resource.data.usuario_id);
      allow create: if request.auth != null && (
        request.resource.data.usuario_id == request.auth.uid ||
        (tienePerfilUsuario() && perfilAuth().id_rancho_jefe == request.resource.data.usuario_id)
      );
      allow update, delete: if puedeEscribirComoDuenoOEmpleado(resource.data.usuario_id);
    }

    match /registro_clinico/{docId} {
      allow read: if puedeLeerRecursoDe(resource.data.usuario_id);
      allow create: if request.auth != null && (
        request.resource.data.usuario_id == request.auth.uid ||
        (isTrabajadorSesion() && request.resource.data.usuario_id == ownerUidTrabajador()) ||
        (tienePerfilUsuario() && perfilAuth().id_rancho_jefe == request.resource.data.usuario_id)
      );
      allow update, delete: if puedeEscribirComoDuenoOEmpleado(resource.data.usuario_id);
    }

    match /tareas/{docId} {
      allow read: if request.auth != null && (
        puedeLeerRecursoDe(resource.data.usuario_id) ||
        resource.data.asignado_a == request.auth.uid
      );
      allow create: if request.auth != null && (
        request.resource.data.usuario_id == request.auth.uid ||
        (tienePerfilUsuario() && perfilAuth().id_rancho_jefe == request.resource.data.usuario_id)
      );
      allow update, delete: if request.auth != null && !isTrabajadorSesion() && (
        resource.data.usuario_id == request.auth.uid ||
        resource.data.asignado_a == request.auth.uid ||
        esEmpleadoDelUsuario(resource.data.usuario_id) ||
        isAdmin()
      );
    }

    match /notificaciones/{docId} {
      allow read: if request.auth != null && resource.data.usuario_id == request.auth.uid;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && resource.data.usuario_id == request.auth.uid;
    }

    match /compras/{docId} {
      allow read, write: if request.auth != null && !isTrabajadorSesion();
    }
    match /calificaciones/{docId} {
      allow read, write: if request.auth != null && !isTrabajadorSesion();
    }
    match /reportes/{docId} {
      allow read, write: if request.auth != null && !isTrabajadorSesion();
    }

    match /animal_certificates/{certId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && !isTrabajadorSesion() &&
        (request.resource.data.usuario_id == request.auth.uid || isAdmin());
      allow update, delete: if false;
    }

    match /lotes_certificado/{loteId} {
      allow read: if request.auth != null && (
        resource.data.usuario_id == request.auth.uid ||
        esEmpleadoDelUsuario(resource.data.usuario_id) ||
        (isTrabajadorSesion() && ownerUidTrabajador() == resource.data.usuario_id)
      );
      allow create: if request.auth != null && !isTrabajadorSesion() &&
        (request.resource.data.usuario_id == request.auth.uid ||
          esEmpleadoDelUsuario(request.resource.data.usuario_id));
      allow update: if request.auth != null && !isTrabajadorSesion() &&
        (resource.data.usuario_id == request.auth.uid || esEmpleadoDelUsuario(resource.data.usuario_id));
      allow delete: if false;
    }

    match /lote_certificates/{certId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && !isTrabajadorSesion() &&
        (request.resource.data.usuario_id == request.auth.uid || isAdmin());
      allow update, delete: if false;
    }

    match /buy_requests/{docId} {
      allow read: if request.auth != null && (
        resource.data.from_user_id == request.auth.uid ||
        resource.data.to_user_id == request.auth.uid
      );
      allow create: if request.auth != null &&
        request.resource.data.from_user_id == request.auth.uid;
      allow update: if request.auth != null && (
        resource.data.from_user_id == request.auth.uid ||
        resource.data.to_user_id == request.auth.uid
      );
      allow delete: if false;
    }

    match /chat_messages/{docId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null &&
        request.resource.data.author_id == request.auth.uid;
      allow update, delete: if false;
    }

    match /deals/{docId} {
      allow read: if request.auth != null && (
        resource.data.buyer_id == request.auth.uid ||
        resource.data.seller_id == request.auth.uid
      );
      allow create: if request.auth != null && (
        request.resource.data.buyer_id == request.auth.uid ||
        request.resource.data.seller_id == request.auth.uid
      );
      allow update: if request.auth != null && (
        resource.data.buyer_id == request.auth.uid ||
        resource.data.seller_id == request.auth.uid
      );
      allow delete: if false;
    }

    match /marketplace_compras/{docId} {
      allow read: if request.auth != null &&
        resource.data.comprador_id == request.auth.uid;
      allow create: if request.auth != null &&
        request.resource.data.comprador_id == request.auth.uid;
      allow update, delete: if request.auth != null &&
        resource.data.comprador_id == request.auth.uid;
    }

    match /marketplace_compras_detalle/{docId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.keys().hasAll(['compra_id'])
        && exists(/databases/$(database)/documents/marketplace_compras/$(request.resource.data.compra_id))
        && get(/databases/$(database)/documents/marketplace_compras/$(request.resource.data.compra_id)).data.comprador_id == request.auth.uid;
      allow update, delete: if false;
    }

    match /reviews/{reviewId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null &&
        request.resource.data.buyerId == request.auth.uid;
      allow update, delete: if false;
    }

    /** Catalogo razas: lectura publica; escritura solo admin. */
    match /razas/{razaId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    /** Contadores internos (solo Admin SDK en practica). */
    match /counters/{docId} {
      allow read, write: if false;
    }

    /** Coleccion animals para tests / emulador. */
    match /animals/{docId} {
      allow read, write: if request.auth != null;
    }
  }
}
